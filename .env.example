###############################################################################
# La Mundial de Seguros - Suscripcion RCV
# Plantilla de variables de entorno
#
# Copia este archivo a .env y rellena los valores. NUNCA subas .env al repo.
# Ejecuta setup.ps1 para que se cree y se generen secrets automaticamente.
###############################################################################


# =============================================================================
# 1) ENTORNO GENERAL
# =============================================================================

# Modo de ejecucion: development | staging | production
NODE_ENV=development

# Nombre publico de la aplicacion (para logs y respuestas)
APP_NAME=RCV-LaMundial


# =============================================================================
# 2) BACKEND (Express)
# =============================================================================

# Puerto en el que escucha el API. Cambialo si 3001 esta ocupado.
PORT=3001

# Lista de origenes permitidos por CORS, separados por coma.
# Incluye los puertos de Vite (5173 por defecto) y el dominio publico.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Limite del body JSON (express.json). Ej: 1mb, 5mb
JSON_BODY_LIMIT=1mb

# Tamano maximo permitido por archivo subido (multer), en MB
UPLOAD_MAX_SIZE_MB=10

# Carpeta destino de uploads (relativa a server/). Por defecto: uploads
UPLOAD_DIR=uploads


# =============================================================================
# 3) SECRETS Y FIRMAS
# Generados automaticamente por setup.ps1 si quedan vacios.
# =============================================================================

# Secret usado para firmar sesiones / tokens internos (>=32 chars).
SESSION_SECRET=

# Secret usado para firmar JWTs (>=32 chars).
JWT_SECRET=

# Tiempo de vida del JWT (ej: 15m, 1h, 7d)
JWT_EXPIRES_IN=12h


# =============================================================================
# 4) PROVEEDOR DE OCR (opcional, para sustituir el OCR simulado)
# =============================================================================

# Proveedor activo: mock | openai | gemini | tesseract | google-document-ai
OCR_PROVIDER=mock

# OpenAI / GPT-4o (si OCR_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (si OCR_PROVIDER=gemini)
# Obtener API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Google Document AI (si OCR_PROVIDER=google-document-ai)
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us
GOOGLE_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=


# =============================================================================
# 5) BASE DE DATOS (opcional, reservado para crecer)
# Hoy el proyecto NO usa DB. Estas variables existen para activarla luego
# sin romper la configuracion.
# =============================================================================

# Postgres
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rcv_lamundial
DB_USER=rcv_user
DB_PASSWORD=

# Redis (cache / colas)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# =============================================================================
# 6) FRONTEND (Vite)
# Variables expuestas al cliente DEBEN llevar prefijo VITE_.
# Vite las lee desde frontend/.env (no desde este archivo).
# setup.ps1 genera frontend/.env automaticamente con los defaults.
# =============================================================================

# URL publica del API (si no se usa el proxy de dev de Vite)
VITE_API_URL=

# Branding
VITE_APP_NAME=La Mundial de Seguros


# =============================================================================
# 7) DESPLIEGUE
# =============================================================================

# Numero de instancias en cluster con PM2 (max | <numero>)
PM2_INSTANCES=max

# Puerto publico del frontend en produccion (servido estaticamente)
PUBLIC_WEB_PORT=4173

# Token opcional de Cloudflare Tunnel (deja vacio para usar el binario local)
CLOUDFLARE_TUNNEL_TOKEN=


# =============================================================================
# 8) LA MUNDIAL DE SEGUROS - API REAL (cotizacion + emision RCV)
# =============================================================================
# IMPORTANTE: el cliente del backend agrega solo el prefijo
# /CorreccionCalculo/api/v1/external. Aqui va solo el host base.
# QA:   https://qaapisys2000.lamundialdeseguros.com
# PROD: <pedir a La Mundial>
LAMUNDIAL_BASE_URL=https://qaapisys2000.lamundialdeseguros.com

# Apikey QA. Header HTTP literal "apikey" (no Authorization, no Bearer).
# En produccion rotar y NO commitear.
LAMUNDIAL_APIKEY=

# Identificadores asignados por La Mundial al integrador.
LAMUNDIAL_PRODUCTOR=80080
LAMUNDIAL_CUSUARIO=4

# Defaults del producto RCV liviano.
LAMUNDIAL_RAMO=18
LAMUNDIAL_PLAN_DEFAULT=RCVBAS
LAMUNDIAL_FRECUENCIA_DEFAULT=A

# Timeout HTTP en ms (La Mundial responde tipicamente en 2-4 s).
LAMUNDIAL_TIMEOUT_MS=30000

# Modo de operacion del endpoint /api/policies/emit:
#   live = llama a la API real de La Mundial (recomendado).
#   mock = devuelve numero ficticio LM-2026-XXXXXX (solo para pruebas UI offline).
POLICY_MODE=live


# =============================================================================
# 9) MERITOP — Gateway de Verificación de Pago Móvil
# =============================================================================
# Meritop actúa como proxy entre el sistema y los bancos venezolanos.
# Solo accesible desde la red interna del banco o VPN autorizada.

# URL principal del servicio Meritop
MERITOP_URL=http://172.30.147.26:9020

# URL del proxy de pagos (usada por el cliente de verificación)
MERITOP_URL2=http://172.30.149.18:9040

# GUID de autenticación (X-API-KEY header en POST /login)
MERITOP_APIKEY=

# IP de origen autorizada por Meritop
MERITOP_IP=

# Credenciales del integrador
MERITOP_USERNAME=
MERITOP_PASSWORD=

# Identificadores asignados por Meritop al integrador
MERITOP_BANK=
MERITOP_CHANNEL=
MERITOP_TERMINAL=

# Habilitar/deshabilitar el módulo. "false" devuelve 503 con mensaje claro.
MERITOP_ENABLED=true

# Timeout HTTP en ms (default: 15000)
MERITOP_TIMEOUT=15000

# Modo prueba (sin acceso a la red interna del banco).
# true  → simula respuesta exitosa con referencia generada (para desarrollar sin VPN).
# false → llama a la API real de Meritop (requiere acceso a 172.30.x.x).
MERITOP_MOCK=false


# =============================================================================
# 10) SYPAGO — Débito OTP
# =============================================================================
# SyPago es una pasarela de cobros venezolana que permite debitar directamente
# la cuenta bancaria del cliente mediante una clave OTP enviada por su banco.
#
# Flujo: solicitar OTP → cliente recibe clave → confirmar con OTP → débito ejecutado
# Documentación: https://pruebas.app.sypago.net/docs/

# URL base de la API de SyPago
# QA:   https://pruebas.api.sypago.net  o  https://pruebas.sypago.net:8086
# PROD: (solicitar a SyPago)
SYPAGO_URL=https://pruebas.sypago.net:8086

# JWT de autenticación (fijo o dinámico ya obtenido del portal SyPago)
SYPAGO_BEARER_TOKEN=

# Cuenta acreedor (la cuenta de La Mundial que recibe el débito)
SYPAGO_BANK_CODE=0108
SYPAGO_TYPE=CNTA
SYPAGO_NUMBER=01086071769795033206

# URL que SyPago llamará con el resultado definitivo de la transacción (webhook).
# En desarrollo puedes usar https://webhook.site/ para inspeccionar las notificaciones.
SYPAGO_WEBHOOK_URL=

# Modo prueba: "true" simula OTP y débito sin llamar a la API real.
SYPAGO_MOCK=false

# Timeout HTTP en ms (default: 20000)
SYPAGO_TIMEOUT=20000


# =============================================================================
# 11) FRONTEND DEV
# =============================================================================

# Puerto del servidor de desarrollo de Vite (default: 5173)
VITE_DEV_PORT=5173
