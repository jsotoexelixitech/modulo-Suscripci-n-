###############################################################################
# La Mundial de Seguros - Suscripcion RCV
# Plantilla de variables de entorno
#
# Copia este archivo a .env y rellena los valores. NUNCA subas .env al repo.
# Ejecuta setup.ps1 para que se cree y se generen secrets automaticamente.
###############################################################################


# =============================================================================
# 1) ENTORNO GENERAL
# =============================================================================

# Modo de ejecucion: development | staging | production
NODE_ENV=development

# Nombre publico de la aplicacion (para logs y respuestas)
APP_NAME=RCV-LaMundial


# =============================================================================
# 2) BACKEND (Express)
# =============================================================================

# Puerto en el que escucha el API. Cambialo si 3001 esta ocupado.
PORT=3001

# Lista de origenes permitidos por CORS, separados por coma.
# Incluye los puertos de Vite (5173 por defecto) y el dominio publico.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Limite del body JSON (express.json). Ej: 1mb, 5mb
JSON_BODY_LIMIT=1mb

# Tamano maximo permitido por archivo subido (multer), en MB
UPLOAD_MAX_SIZE_MB=10

# Carpeta destino de uploads (relativa a server/). Por defecto: uploads
UPLOAD_DIR=uploads


# =============================================================================
# 3) SECRETS Y FIRMAS
# Generados automaticamente por setup.ps1 si quedan vacios.
# =============================================================================

# Secret usado para firmar sesiones / tokens internos (>=32 chars).
SESSION_SECRET=

# Secret usado para firmar JWTs (>=32 chars).
JWT_SECRET=

# Tiempo de vida del JWT (ej: 15m, 1h, 7d)
JWT_EXPIRES_IN=12h


# =============================================================================
# 4) PROVEEDOR DE OCR (opcional, para sustituir el OCR simulado)
# =============================================================================

# Proveedor activo: mock | openai | gemini | tesseract | google-document-ai
OCR_PROVIDER=mock

# OpenAI / GPT-4o (si OCR_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (si OCR_PROVIDER=gemini)
# Obtener API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Google Document AI (si OCR_PROVIDER=google-document-ai)
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us
GOOGLE_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=


# =============================================================================
# 5) BASE DE DATOS (opcional, reservado para crecer)
# Hoy el proyecto NO usa DB. Estas variables existen para activarla luego
# sin romper la configuracion.
# =============================================================================

# Postgres
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rcv_lamundial
DB_USER=rcv_user
DB_PASSWORD=

# Redis (cache / colas)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# =============================================================================
# 6) FRONTEND (Vite)
# Variables expuestas al cliente DEBEN llevar prefijo VITE_.
# Vite las lee desde frontend/.env (no desde este archivo).
# setup.ps1 genera frontend/.env automaticamente con los defaults.
# =============================================================================

# URL publica del API (si no se usa el proxy de dev de Vite)
VITE_API_URL=

# Branding
VITE_APP_NAME=La Mundial de Seguros


# =============================================================================
# 7) DESPLIEGUE
# =============================================================================

# Numero de instancias en cluster con PM2 (max | <numero>)
PM2_INSTANCES=max

# Puerto publico del frontend en produccion (servido estaticamente)
PUBLIC_WEB_PORT=4173

# Token opcional de Cloudflare Tunnel (deja vacio para usar el binario local)
CLOUDFLARE_TUNNEL_TOKEN=
